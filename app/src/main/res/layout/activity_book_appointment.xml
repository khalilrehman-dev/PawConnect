<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Vet info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvVetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvClinicName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clinic Name"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Select Pet -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Pet"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerPet"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Tap to select date"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp" />

        <!-- Time -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Time"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Tap to select time"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp" />

        <!-- Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Reason for visit (optional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#1A1A1A"
            app:hintTextColor="#1A1A1A"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A1A"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnBook"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Confirm Appointment"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:indeterminate="true" />

    </LinearLayout>
</ScrollView>